* text=auto eol=lf

# Explicitly declare text files
*.sh text eol=lf
*.php text eol=lf
*.js text eol=lf
*.css text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.md text eol=lf
.env text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary

# Export-ignore (jangan include di archive)
.env export-ignore
.gitattributes export-ignore